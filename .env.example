# Environment Configuration
# Copy to .env and fill with actual values

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=cyber2u_user
DB_PASSWORD=developmentpassword
DB_NAME=cyber2u_db

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Email (using MailHog for local development)
EMAIL_FROM=noreply@cyber2u.local
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASS=

# FormSubmit.co
FORMSUBMIT_ENDPOINT=https://formsubmit.co

# Analytics (Optional for Phase 8+)
ANALYTICS_ENABLED=false
ANALYTICS_ENGINE=postgresql
